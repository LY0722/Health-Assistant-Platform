
/* 搜索栏样式 */
.search-container.data-v-c1a2745a {
  padding: 20rpx;
  background: #fff;
}
.search-bar.data-v-c1a2745a {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  height: 70rpx;
}
.search-icon.data-v-c1a2745a {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}
.search-input.data-v-c1a2745a {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}
.clear-icon.data-v-c1a2745a {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
  font-size: 32rpx;
  color: #999;
  text-align: center;
  line-height: 32rpx;
}
.placeholder-style.data-v-c1a2745a {
  color: #999;
  font-size: 28rpx;
}
/* 左右布局 */
.main-container.data-v-c1a2745a {
  display: flex;
  height: calc(100vh - 200rpx);
}
.category-nav.data-v-c1a2745a {
  width: 180rpx;
  background: #f8f8f8;
}
.category-item.data-v-c1a2745a {
  padding: 25rpx 10rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}
.category-item.active.data-v-c1a2745a {
  background: #e6f2ff;
  color: #537bff;
  font-weight: bold;
}
.product-list.data-v-c1a2745a {
  flex: 1;
  padding: 20rpx;
}
.select-circle.data-v-c1a2745a {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.inner-circle.data-v-c1a2745a {
  width: 24rpx;
  height: 24rpx;
  background-color: #537bff;
  border-radius: 50%;
}
.product-card.data-v-c1a2745a {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.product-image.data-v-c1a2745a {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}
.product-info.data-v-c1a2745a {
  flex: 1;
  padding: 0 20rpx;
}
.product-name.data-v-c1a2745a {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.product-desc.data-v-c1a2745a {
  font-size: 24rpx;
  color: #666;
  margin: 10rpx 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.price-section.data-v-c1a2745a {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.current-price.data-v-c1a2745a {
  color: #f40;
  font-weight: bold;
  font-size: 32rpx;
}
.sales.data-v-c1a2745a {
  color: #999;
  font-size: 24rpx;
}

/* 购物车样式 - 全新设计 */
.cart-bar.data-v-c1a2745a {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
  z-index: 100;
}
.cart-info.data-v-c1a2745a {
  display: flex;
  align-items: center;
  flex: 1;
}
.cart-icon-wrapper.data-v-c1a2745a {
  position: relative;
  margin-right: 20rpx;
}
.cart-icon.data-v-c1a2745a {
  width: 48rpx;
  height: 48rpx;
}
.cart-badge.data-v-c1a2745a {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  background: #f23030;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
  color: #fff;
  padding: 0 6rpx;
}
.cart-text.data-v-c1a2745a {
  display: flex;
  flex-direction: column;
}
.cart-amount.data-v-c1a2745a {
  color: #f23030;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 4rpx;
}
.checkout-btn.data-v-c1a2745a {
  background: #537bff;
  color: #fff;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.checkout-btn.disabled.data-v-c1a2745a {
  background: #ccc;
  color: #999;
}
