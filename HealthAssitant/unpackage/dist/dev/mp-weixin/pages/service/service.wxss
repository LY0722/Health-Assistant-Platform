
.data-v-cb2df937:root {
  --primary-color: #007AFF;
  --card-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  --border-radius-base: 16rpx;
  --border-radius-sm: 8rpx;
}

/* 通用样式 */
.page-content.data-v-cb2df937 {
  background-color: #f9f9f9;
}
.app-name.data-v-cb2df937 {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

/* 轮播图样式 */
.banner-container.data-v-cb2df937 {
  padding: 20rpx 30rpx;
  background-color: white;
}
.banner.data-v-cb2df937 {
  height: 300rpx;
  border-radius: var(--border-radius-base);
  overflow: hidden;
}
.banner-image.data-v-cb2df937 {
  width: 100%;
  height: 100%;
}

/* 功能入口样式 */
.feature-grid.data-v-cb2df937 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: var(--card-shadow);
  margin-top: 20rpx;
}
.feature-item.data-v-cb2df937 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.feature-icon.data-v-cb2df937 {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}
.feature-text.data-v-cb2df937 {
  font-size: 26rpx;
  color: #333;
}

/* 模块标题样式 */
.module-section.data-v-cb2df937 {
  margin-top: 30rpx;
  padding: 0 30rpx;
}
.module-header.data-v-cb2df937 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.module-title.data-v-cb2df937 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.module-more.data-v-cb2df937 {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 健康卡片样式 */
.health-cards.data-v-cb2df937 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.health-card-row.data-v-cb2df937 {
  display: flex;
  gap: 20rpx;
}

/* 第一行卡片样式 */
.health-card-row:first-child .health-card.data-v-cb2df937 {
  flex: 1;
  height: 200rpx;
  border-radius: var(--border-radius-base);
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}
.health-card.with-image.data-v-cb2df937 {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}
.card-text-content.data-v-cb2df937 {
  flex: 1;
  z-index: 2;
  position: relative;
  padding-right: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.card-image.data-v-cb2df937 {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  width: 40%; /* 固定宽度 */
  object-fit: cover;
  z-index: 1;
  opacity: 0.8;
}

/* 第二行卡片样式 */
.health-card-row:last-child .health-card.data-v-cb2df937 {
  flex: 1;
  height: 150rpx;
  border-radius: var(--border-radius-base);
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* 卡片文字样式 */
.card-title.data-v-cb2df937 {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: white;
}
.card-subtitle.data-v-cb2df937 {
  font-size: 24rpx;
  color: white;
}

/* 文字对齐方式 */
.health-card.with-image .card-title.data-v-cb2df937,
.health-card.with-image .card-subtitle.data-v-cb2df937 {
  text-align: left;
}
.health-card:not(.with-image) .card-title.data-v-cb2df937,
.health-card:not(.with-image) .card-subtitle.data-v-cb2df937,
.health-card.small .card-title.data-v-cb2df937,
.health-card.small .card-subtitle.data-v-cb2df937 {
  text-align: center;
}

/* 悬停效果 */
.health-card.data-v-cb2df937:hover {
  transform: translateY(-5rpx);
}

/* 医生卡片样式 */
.doctor-cards.data-v-cb2df937 {
  margin-bottom: 100rpx;
}
.doctor-card.data-v-cb2df937 {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  display: flex;
  margin-bottom: 20rpx;
  transition: transform 0.3s ease;
}
.doctor-card.data-v-cb2df937:hover {
  transform: translateX(10rpx);
}
.doctor-avatar.data-v-cb2df937 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.doctor-content.data-v-cb2df937 {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.doctor-name.data-v-cb2df937 {
  font-size: 28rpx;
  font-weight: bold;
}
.doctor-title.data-v-cb2df937,
.doctor-department.data-v-cb2df937 {
  font-size: 24rpx;
  color: #666;
}
