
.common-page.data-v-7aa7d5ae {
  background-color: #f8f9fa;
  min-height: 100vh;
}

/* 评测选择样式 - 修改后的卡片样式 */
.assessment-selector.data-v-7aa7d5ae {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.type-card.data-v-7aa7d5ae {
  height: 350rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}
.type-card.data-v-7aa7d5ae:active {
  transform: scale(0.98);
}
.card-image.data-v-7aa7d5ae {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.card-content.data-v-7aa7d5ae {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
}
.type-title.data-v-7aa7d5ae {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}
.type-desc.data-v-7aa7d5ae {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}
.start-btn.data-v-7aa7d5ae {
  background-color: rgba(255, 255, 255, 0.9);
  color: #537bff;
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  align-self: flex-start;
  transition: all 0.3s ease;
}
.type-card:active .start-btn.data-v-7aa7d5ae {
  background-color: #fff;
}


/* 问卷样式 */
.assessment-container.data-v-7aa7d5ae {
  padding: 30rpx;
}
.progress-container.data-v-7aa7d5ae {
  margin-bottom: 40rpx;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.progress-text.data-v-7aa7d5ae {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}
progress.data-v-7aa7d5ae {
  width: 100%;
}
.question-card.data-v-7aa7d5ae {
  background-color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.question-text.data-v-7aa7d5ae {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
}
.options.data-v-7aa7d5ae {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option.data-v-7aa7d5ae {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #eee;
  transition: all 0.3s ease;
  font-size: 28rpx;
}
.option.data-v-7aa7d5ae:active {
  transform: translateY(5rpx);
}

