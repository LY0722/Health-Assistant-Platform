

/* 文章容器 */
.article-container.data-v-2f0cb08d {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 文章头部 */
.article-header.data-v-2f0cb08d {
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 30rpx;
}
.article-category.data-v-2f0cb08d {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: #e6f7ff;
  color: #1890ff;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}
.article-title.data-v-2f0cb08d {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.article-meta.data-v-2f0cb08d {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.article-author.data-v-2f0cb08d {
  font-size: 26rpx;
  color: #666;
}
.article-date.data-v-2f0cb08d {
  font-size: 24rpx;
  color: #999;
}

/* 文章内容 */
.article-content.data-v-2f0cb08d {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}
.article-content text.data-v-2f0cb08d {
  display: block;
  margin-bottom: 30rpx;
}
